# Viral Command — Environment Variables
# Copy this file to .env and fill in your API keys.
# See SETUP.md for where to get each key.

# ──────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────

# OpenAI — Whisper transcription + LLM scoring in recon module
OPENAI_API_KEY=your_openai_api_key_here

# YouTube Data API v3 — analytics collection, thumbnail fetch, search
YOUTUBE_DATA_API_KEY=your_youtube_data_api_key_here

# ──────────────────────────────────────
# OPTIONAL
# ──────────────────────────────────────

# Anthropic — used by recon skeleton ripper for LLM calls (falls back to OpenAI if not set)
# ANTHROPIC_API_KEY=

# Google API — additional Google service access
# GOOGLE_API_KEY=

# ──────────────────────────────────────
# SUBTEXT NOTIFICATIONS (scripts/subtext_notify.py)
# ──────────────────────────────────────

# ntfy phone push — subscribe to this exact topic in the ntfy app (ntfy.sh).
# Pick an unguessable value; anyone who knows the topic can read your pushes.
# SUBTEXT_NTFY_TOPIC=subtext-xxxxxxxxxxxx

# Email digest — Gmail app password (NOT your login password).
# Create at: Google Account → Security → 2-Step Verification → App passwords.
# Locked to send from/to the same personal address (Identity Gate safe).
# SUBTEXT_SMTP_USER=bigsidd@gmail.com
# SUBTEXT_SMTP_PASS=your_16_char_app_password
# SUBTEXT_EMAIL_TO=bigsidd@gmail.com   # defaults to SUBTEXT_SMTP_USER if unset

# ──────────────────────────────────────
# INSTAGRAM (run scripts/setup-ig-token.py to populate)
# ──────────────────────────────────────

# Instagram Graph API — per-Reel insights, follower growth
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
